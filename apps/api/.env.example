# Database
DATABASE_URL="postgresql://flowbooks:flowbooks_dev@localhost:5432/flowbooks?schema=public"

# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000

# Comma-separated emails that become super admin on register/login
# SUPER_ADMIN_EMAILS=you@example.com

# One-time DB wipe (POST /api/v1/maintenance/reset-data with header x-reset-token)
# Remove this variable after cleanup.
# MAINTENANCE_RESET_TOKEN=change-me-then-delete

# Single-user local mode (no login screen)
LOCAL_SINGLE_USER=true
LOCAL_USER_EMAIL=owner@local
LOCAL_USER_NAME=Owner
LOCAL_USER_PASSWORD=soloflow

# Storage (S3-compatible)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# AWS S3 (production)
# STORAGE_PROVIDER=s3
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=flowbooks-uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_ENDPOINT=

# Google OAuth (for web app reference)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
