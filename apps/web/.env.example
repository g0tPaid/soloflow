# Auth.js
AUTH_SECRET=change-me-in-production-use-long-random-string
AUTH_URL=http://localhost:3000

# Google OAuth (optional)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# API
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
API_URL=http://localhost:3001

# Local single-user mode (skip login — auto sign in). Set false for hosted / Play Store app.
NEXT_PUBLIC_LOCAL_MODE=false

# Database (for Auth.js Prisma adapter if needed)
DATABASE_URL="postgresql://flowbooks:flowbooks_dev@localhost:5432/flowbooks?schema=public"
