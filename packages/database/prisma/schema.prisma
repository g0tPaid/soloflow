// FlowBooks Database Schema
// Multi-tenant accounting SaaS foundation

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (Auth.js compatible) ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  isSuperAdmin  Boolean   @default(false)
  suspendedAt   DateTime?
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   OrganizationMember[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Multi-Tenant ────────────────────────────────────────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  ACCOUNTANT
  SALES
  EMPLOYEE
  CUSTOM
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings          OrganizationSettings?
  members           OrganizationMember[]
  customRoles       CustomRole[]
  customers         Customer[]
  vendors           Vendor[]
  products          Product[]
  invoices          Invoice[]
  quotes            Quote[]
  auditLogs         AuditLog[]
  customFieldDefs   CustomFieldDefinition[]
  featureFlags      FeatureFlag[]

  @@map("organizations")
}

model OrganizationSettings {
  id             String @id @default(cuid())
  organizationId String @unique

  currency       String  @default("USD")
  /// Currency used for dashboard totals display
  dashboardCurrency String @default("USD")
  /// When false, dashboard and expenses skip FX conversion
  fxEnabled      Boolean @default(true)
  /// Currency staff use when entering purchase/shipping costs on expenses
  costCurrency   String  @default("CNY")
  timezone       String  @default("UTC")
  dateFormat     String  @default("YYYY-MM-DD")
  fiscalYearStart Int    @default(1) // month 1-12
  branding       Json    @default("{}")
  taxConfig      Json    @default("{}")
  /// Units of each currency per 1 USD, e.g. { "USD": 1, "CNY": 7.25, "EUR": 0.92 }
  fxRates        Json    @default("{\"USD\":1,\"CNY\":7.25,\"EUR\":0.92,\"GBP\":0.79}")
  invoicePrefix  String  @default("INV")
  invoiceNextNum Int     @default(1)
  quotePrefix    String  @default("QUO")
  quoteNextNum   Int     @default(1)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(EMPLOYEE)
  customRoleId   String?
  permissions    Json       @default("[]")
  invitedAt      DateTime?
  joinedAt       DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole   CustomRole?  @relation(fields: [customRoleId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model CustomRole {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  permissions    Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("custom_roles")
}

// ─── Feature Flags / Plugin Architecture ─────────────────────────────────────

model FeatureFlag {
  id             String  @id @default(cuid())
  organizationId String
  key            String
  enabled        Boolean @default(false)
  config         Json    @default("{}")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("feature_flags")
}

// ─── Business Entities ───────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  currency       String   @default("INR")
  address        Json     @default("{}")
  taxId          String?
  notes          String?
  customFields   Json     @default("{}")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  quotes       Quote[]

  @@index([organizationId])
  @@index([organizationId, email])
  @@map("customers")
}

model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  currency       String   @default("INR")
  address        Json     @default("{}")
  taxId          String?
  notes          String?
  customFields   Json     @default("{}")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([organizationId])
  @@index([organizationId, email])
  @@map("vendors")
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  sku            String?
  imageUrl       String?
  unitPrice      Decimal  @default(0) @db.Decimal(12, 2)
  currency       String   @default("USD")
  taxRate        Decimal  @default(0) @db.Decimal(5, 4)
  isActive       Boolean  @default(true)
  customFields   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
  quoteItems   QuoteItem[]

  @@index([organizationId])
  @@index([organizationId, sku])
  @@map("products")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
  VOID
}

enum ShippingMethod {
  AIR
  SEA
  LOCAL
}

enum ShippingTerms {
  DDP
  LCL
  LOCAL
}

model Invoice {
  id                  String           @id @default(cuid())
  organizationId      String
  /// Required for normal invoices; optional on expense records that use vendorId instead
  customerId          String?
  vendorId            String?
  number              String
  status              InvoiceStatus    @default(DRAFT)
  issueDate           DateTime         @default(now())
  dueDate             DateTime?
  currency            String           @default("USD")
  subtotal            Decimal          @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal          @default(0) @db.Decimal(12, 2)
  /// Invoice-level VAT percent (e.g. 5 = 5%). 0 means VAT off.
  taxRate             Decimal          @default(0) @db.Decimal(5, 2)
  /// Purchase/input VAT percent on vendor expense records (UAE recoverable VAT).
  inputTaxRate        Decimal          @default(0) @db.Decimal(5, 2)
  /// Purchase/input VAT amount (currency of the invoice).
  inputTaxAmount      Decimal          @default(0) @db.Decimal(12, 2)
  shipping            Decimal          @default(0) @db.Decimal(12, 2)
  shippingCost        Decimal          @default(0) @db.Decimal(12, 2)
  shippingCostCny     Decimal          @default(0) @db.Decimal(12, 2)
  discount            Decimal          @default(0) @db.Decimal(12, 2)
  total               Decimal          @default(0) @db.Decimal(12, 2)
  totalCost           Decimal          @default(0) @db.Decimal(12, 2)
  shippingMethod      ShippingMethod?
  shippingTerms       ShippingTerms?
  shippingFromCountry String?
  shippingToCountry   String?
  notes               String?
  customFields        Json             @default("{}")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id])
  vendor       Vendor?       @relation(fields: [vendorId], references: [id])
  items        InvoiceItem[]
  sourceQuotes Quote[]       @relation("QuoteConvertedInvoice")

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, customerId])
  @@index([organizationId, vendorId])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  name        String?
  description String
  imageUrl    String?
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  unitCost    Decimal @default(0) @db.Decimal(12, 2)
  unitCostCny Decimal @default(0) @db.Decimal(12, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 4)
  amount      Decimal @default(0) @db.Decimal(12, 2)
  costAmount  Decimal @default(0) @db.Decimal(12, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
  CONVERTED
}

model Quote {
  id                  String        @id @default(cuid())
  organizationId      String
  customerId          String
  number              String
  status              QuoteStatus   @default(DRAFT)
  issueDate           DateTime      @default(now())
  /// Valid until (mirrors invoice dueDate)
  validUntil          DateTime?
  currency            String        @default("USD")
  subtotal            Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal       @default(0) @db.Decimal(12, 2)
  taxRate             Decimal       @default(0) @db.Decimal(5, 2)
  shipping            Decimal       @default(0) @db.Decimal(12, 2)
  discount            Decimal       @default(0) @db.Decimal(12, 2)
  total               Decimal       @default(0) @db.Decimal(12, 2)
  shippingMethod      ShippingMethod?
  shippingTerms       ShippingTerms?
  shippingFromCountry String?
  shippingToCountry   String?
  notes               String?
  convertedInvoiceId  String?
  customFields        Json          @default("{}")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer         Customer     @relation(fields: [customerId], references: [id])
  convertedInvoice Invoice?     @relation("QuoteConvertedInvoice", fields: [convertedInvoiceId], references: [id], onDelete: SetNull)
  items            QuoteItem[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, customerId])
  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  productId   String?
  name        String?
  description String
  imageUrl    String?
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 4)
  amount      Decimal @default(0) @db.Decimal(12, 2)

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([quoteId])
  @@map("quote_items")
}

// ─── Extensibility ───────────────────────────────────────────────────────────

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
}

model CustomFieldDefinition {
  id             String          @id @default(cuid())
  organizationId String
  entityType     String // customer, product, invoice, etc.
  fieldKey       String
  label          String
  fieldType      CustomFieldType @default(TEXT)
  options        Json            @default("[]")
  required       Boolean         @default(false)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entityType, fieldKey])
  @@index([organizationId, entityType])
  @@map("custom_field_definitions")
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json     @default("{}")
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, entityType])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}
